# Portl Server Production Environment Configuration
NODE_ENV=production
PORT=3000

# Neon PostgreSQL Database Connection URL
DATABASE_URL="postgresql://user:password@ep-xyz.neon.tech/portl?sslmode=require"

# Better Auth Configuration
BETTER_AUTH_SECRET="your_production_better_auth_secret_here"
BETTER_AUTH_URL="https://portl-api.ayushbhagat.com"

# CORS Origin Allowed Client
CORS_ORIGIN="https://portl-api.ayushbhagat.com"

# Resend API Key & Verified Sender Email
RESEND_API_KEY="re_123456789"
EMAIL_FROM="Portl Gate <noreply@email.ayushbhagat.com>"

# Cloudinary Storage Configuration
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Razorpay Payments Configuration
RAZORPAY_KEY_ID="rzp_live_xxx"
RAZORPAY_KEY_SECRET="xxx"
